{
  "main": "desktop/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "desktop": "electron .",
    "desktop:build": "electron-builder --win",
    "desktop:build:portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "gg.relayed.desktop",
    "productName": "Relayed",
    "directories": {
      "output": "dist"
    },
    "files": [
      "desktop/**/*",
      "build/**/*",
      ".next/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Relayed"
    }
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
